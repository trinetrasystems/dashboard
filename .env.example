# ────────────────────────────────────────────────────────────────────────────
# Trinetra Systems Monitor — environment file
#
# 1. Copy this file to `.env` (in the project root, next to backend/ and frontend/)
# 2. Edit values to match your machine
# 3. Restart the server (python3 app.py) — .env is read at startup
#
# Lines starting with # are comments. Blank lines are ignored.
# Quotes around values are optional — both `KEY=value` and `KEY="value"` work.
# Use forward slashes / on Linux AND Windows — Python normalizes them.
# Absolute paths work everywhere; relative paths are relative to where you run python from.
# ────────────────────────────────────────────────────────────────────────────


# ─── PATHS ─────────────────────────────────────────────────────────────────
# Where SQLite database + image archive + incoming folder live.
# Default if unset: ./data (relative to project root)

# Linux example:
# TRINETRA_DATA=/home/jetson/trinetra-data

# Windows example:
# TRINETRA_DATA=C:/Users/Pratik/trinetra-data

# Default (works on both, recommended for dev):
TRINETRA_DATA=./data


# Path to classes.txt — your YOLO badge labels.
# Default if unset: backend/classes.txt
# TRINETRA_CLASSES=./backend/classes.txt


# Frontend folder location (rarely changed).
# Default if unset: ./frontend
# TRINETRA_FRONTEND=./frontend


# ─── SERVER ────────────────────────────────────────────────────────────────
TRINETRA_HOST=0.0.0.0
TRINETRA_PORT=8000


# ─── JETSON REGISTRY ───────────────────────────────────────────────────────
# Comma-separated list of expected Jetsons.
# Topbar shows "X / Y JETSONS ONLINE" where Y is the count below.
TRINETRA_JETSONS=central,edge-1,edge-2,edge-3

# Seconds after which a heartbeat is considered stale (jetson offline).
TRINETRA_HB_STALE=90


# ─── DETECTION / LOITERING SETTINGS ────────────────────────────────────────
# Alert when a badge has been in premises this many minutes.
TRINETRA_LOITER_MINUTES=15

# Gap (in minutes) between sightings that splits one session from the next.
# Same badge re-detected within this window extends the session; longer than
# this window closes the old session and opens a new one.
TRINETRA_SESSION_GAP_MINUTES=5

# How long (in minutes) a session can stay "open" with no new detection before
# being auto-closed. After this, if the same badge appears again (e.g. the
# security person handed the badge to someone else), a fresh session opens
# so the two visits are tracked as separate people.
TRINETRA_SESSION_AUTO_CLOSE_MINUTES=10

# Comma-separated list of cameras whose detections close the session (exit gates).
# When a badge is seen here, the session ends and the badge leaves "in premises".
TRINETRA_EXIT_CAMERAS=cam-gate


# ─── NOTIFICATIONS (optional, leave blank to disable) ──────────────────────

# Telegram — get token from @BotFather, chat_id from getUpdates API
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Email (Gmail SMTP example — needs an App Password, not your real password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_TO=
